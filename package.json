{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "start": "node dist/server.js",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:e2e": "node -e \"const fs = require('fs'); try { fs.rmSync('reports/results', { recursive: true, force: true }); } catch (e) {}\" && npx playwright test",
    "test:e2e:headed": "node -e \"const fs = require('fs'); try { fs.rmSync('reports/results', { recursive: true, force: true }); } catch (e) {}\" && npx playwright test --headed",
    "test:e2e:report": "npx playwright show-report reports/playwright-html",
    "test:e2e:selenium": "mocha tests/mocha-e2e.spec.js --reporter mochawesome --reporter-options reportDir=reports,reportFilename=selenium-report",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "cap:build:android": "npm run build && npx cap sync android",
    "cap:run:android": "npm run build && npx cap sync android && npx cap run android",
    "cap:add:android": "npx cap add android"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/device": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-is": "^19.2.7",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.61.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "firebase": "^10.14.1",
    "firebase-admin": "^14.0.0",
    "jest": "^30.4.2",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "selenium-webdriver": "^4.44.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "ts-jest": "^29.4.11",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  }
}
