rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global fallback - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY UTILITIES ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- SCHEMA VALIDATION BLUEPRINTS ---

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('name' in data) || (data.name is string && data.name.size() <= 128))
        && data.email is string && data.email.size() <= 256
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2048))
        && data.role is string && data.role.size() <= 64
        && data.xp is int && data.xp >= 0 && data.xp < 1000000
        && data.level is int && data.level >= 1 && data.level <= 100
        && data.coins is int && data.coins >= 0 && data.coins <= 100000
        && data.streak is int && data.streak >= 0 && data.streak <= 10000
        && (data.lastActive is string || data.lastActive is timestamp)
        && (data.lastLoginAt is string || data.lastLoginAt is timestamp)
        && (!('badges' in data) || (data.badges is list && data.badges.size() <= 50))
        && (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidNote(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 256
        && data.content is string && data.content.size() <= 50000
        && data.summary is string && data.summary.size() <= 10000
        && (!('flashcards' in data) || (data.flashcards is list && data.flashcards.size() <= 100))
        && data.createdAt is string && data.createdAt.size() <= 128
        && (!('isRawResponseFallback' in data) || data.isRawResponseFallback is bool)
        && (!('rawText' in data) || (data.rawText is string && data.rawText.size() <= 100000));
    }

    function isValidQuiz(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 256
        && data.questions is list && data.questions.size() <= 50
        && (!('score' in data) || (data.score is int && data.score >= 0 && data.score <= 100))
        && data.createdAt is string && data.createdAt.size() <= 128
        && (!('isRawResponseFallback' in data) || data.isRawResponseFallback is bool)
        && (!('rawText' in data) || (data.rawText is string && data.rawText.size() <= 100000));
    }

    function isValidRoadmap(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.subject is string && data.subject.size() <= 256
        && data.durationDays is int && data.durationDays >= 1 && data.durationDays <= 365
        && data.steps is list && data.steps.size() <= 100
        && data.createdAt is string && data.createdAt.size() <= 128;
    }

    function isValidChatMessage(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.sender is string && (data.sender == 'user' || data.sender == 'ai')
        && data.text is string && data.text.size() <= 10000
        && data.timestamp is string && data.timestamp.size() <= 128;
    }

    // --- COLLECTION RULES MATCH BLOCKS ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (
        (isAdmin() && isValidUser(incoming())) ||
        (isOwner(userId) && isValidUser(incoming()) &&
          incoming().diff(existing()).affectedKeys().hasOnly([
            'displayName', 'name', 'photoURL', 'xp', 'level', 'coins', 'streak', 'lastActive', 'lastLoginAt', 'badges'
          ])
        )
      );
    }

    match /notes/{noteId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidNote(incoming()) && isValidId(noteId);
      allow update: if isSignedIn() && isOwner(existing().userId) && isOwner(incoming().userId) && isValidNote(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'summary', 'flashcards'])
      );
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /quizzes/{quizId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidQuiz(incoming()) && isValidId(quizId);
      allow update: if isSignedIn() && isOwner(existing().userId) && isOwner(incoming().userId) && isValidQuiz(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['score'])
      );
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /roadmaps/{roadmapId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidRoadmap(incoming()) && isValidId(roadmapId);
      allow update: if isSignedIn() && isOwner(existing().userId) && isOwner(incoming().userId) && isValidRoadmap(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['steps'])
      );
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /chat_histories/{messageId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidChatMessage(incoming()) && isValidId(messageId);
      allow update: if false; // Historical chat messages are immutable once created
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
